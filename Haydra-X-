local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Crypt = require(ReplicatedStorage:WaitForChild("Crypt"))
local meleeRemote = ReplicatedStorage.remoteInterface.interactions.meleePlayer

local function fireAtTarget(target)
local part = target.Character.RightUpperArm
local k1, k2, k3 = Crypt.checkpublickeys()
meleeRemote:FireServer(1, Crypt.crypt(k1, math.abs(target.UserId) + k3, k2), part, part.CFrame)
end
